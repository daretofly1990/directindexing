FINNHUB_API_KEY=your_finnhub_api_key_here
JWT_SECRET=generate-with-openssl-rand-hex-32
ADMIN_EMAIL=admin@yourfirm.com
ADMIN_PASSWORD=choose-a-strong-password
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# SQLite (local dev, no Docker):
DATABASE_URL=sqlite+aiosqlite:///./direct_indexing.db
# PostgreSQL (docker-compose / production):
# DATABASE_URL=postgresql+asyncpg://di:di_secret@db:5432/direct_indexing

# Anthropic — required for the live AI harvest advisor. Leave blank for demo mode.
ANTHROPIC_API_KEY=

# Claude model per subscription tier. Both default to opus-4-5 during dev.
# After launch, flip CLAUDE_MODEL_DEFAULT to claude-haiku-4-5 to save ~95%
# on API cost for starter/standard users — premium keeps opus. See
# docs/TODO.md M6 for the Anthropic upgrade playbook when new models ship.
CLAUDE_MODEL_DEFAULT=claude-opus-4-5
CLAUDE_MODEL_PREMIUM=claude-opus-4-5

# PII column encryption (Fernet). First key is primary; extras support rotation.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# LOSE THIS KEY AND YOU LOSE THE DATA — back it up to your secrets manager.
FIELD_ENCRYPTION_KEYS=

# Structured JSON logs (set to 1 in production for CloudWatch/Datadog/Loki ingestion)
JSON_LOGS=0

# SMTP for email verification. When SMTP_HOST is empty, emails log to stdout
# instead of sending — fine for local dev, NOT fine in prod.
#
# --- Default: Mailtrap ---
#   Sandbox (dev/staging — catches every mail in a virtual inbox, never delivers):
#     SMTP_HOST=sandbox.smtp.mailtrap.io   SMTP_PORT=2525  (also 25, 465, 587)
#     SMTP_USER=<mailtrap-username>        SMTP_PASSWORD=<mailtrap-password>
#     -> https://mailtrap.io/ → Email Testing → Inboxes → SMTP Settings
#
#   Live sending (when you're ready to actually deliver mail):
#     SMTP_HOST=live.smtp.mailtrap.io      SMTP_PORT=587
#     SMTP_USER=api                        SMTP_PASSWORD=<mailtrap-api-token>
#     -> Email Sending → Sending Domains → verify DNS → API Tokens
#
# --- Other providers (uncomment one block, delete the Mailtrap lines) ---
#   SendGrid:  SMTP_HOST=smtp.sendgrid.net         SMTP_PORT=587
#              SMTP_USER=apikey                    SMTP_PASSWORD=<SG.xxx...>
#   Postmark:  SMTP_HOST=smtp.postmarkapp.com      SMTP_PORT=587
#              SMTP_USER=<server-token>            SMTP_PASSWORD=<server-token>
#   Mailgun:   SMTP_HOST=smtp.mailgun.org          SMTP_PORT=587
#              SMTP_USER=postmaster@mg.yourdomain.com
#              SMTP_PASSWORD=<smtp-password>
#   AWS SES:   SMTP_HOST=email-smtp.us-east-1.amazonaws.com  SMTP_PORT=587
#              (generate SES SMTP creds in the SES console, not regular IAM)
#   Gmail:     SMTP_HOST=smtp.gmail.com            SMTP_PORT=587
#              SMTP_PASSWORD=<16-char-app-password>
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@yourdomain.com
APP_BASE_URL=https://app.yourdomain.com

# Stripe billing (M8). When empty, /api/billing/* returns 503. Get price IDs
# from the Stripe dashboard after creating products for starter/standard/premium.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_ANNUAL=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_ANNUAL=
STRIPE_TRIAL_DAYS=14

# Sentry error tracking (M7 ops). Empty = disabled. Create a project at
# https://sentry.io and paste the DSN.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# 0.0 = no perf traces, 1.0 = every request. Start at 0.05 in prod.
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
APP_VERSION=1.0.0

# AWS (Secrets Manager lookup + S3 backups).
# Uses the standard boto3 credential chain — AWS_PROFILE, AWS_ACCESS_KEY_ID/
# AWS_SECRET_ACCESS_KEY, or IAM role if running on EC2/ECS/Fargate.
AWS_REGION=us-east-1
# When set + IAM allows, secrets like JWT_SECRET are fetched from
# <prefix>/jwt_secret at boot. Empty disables AWS lookup.
AWS_SECRETS_PREFIX=direct-indexing/
# Bucket for nightly pg_dumps. Empty disables backups.
S3_BACKUP_BUCKET=
S3_BACKUP_PREFIX=pgdumps/
S3_BACKUP_RETENTION_DAYS=30

# TOTP admin MFA (M7). ISSUER is shown in the authenticator app next to the code.
TOTP_ISSUER=DirectIndex Pro
